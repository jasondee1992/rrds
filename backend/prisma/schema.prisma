generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InquirySource {
  CONTACT_FORM
  CHATBOT
  PHONE
  EMAIL
  MANUAL
}

enum EstimateRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ESTIMATE_READY
  CONVERTED_TO_QUOTATION
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  READY
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum QuotationItemType {
  PRODUCT
  SERVICE
  LABOR
  MATERIAL
  TRANSPORTATION
  TRANIT
  OTHER
}

model AdminUser {
  id                 String             @id @default(uuid())
  fullName           String
  email              String             @unique
  passwordHash       String
  role               AdminRole          @default(STAFF)
  isActive           Boolean            @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  preparedQuotations Quotation[]        @relation("PreparedQuotations")
  approvedQuotations Quotation[]        @relation("ApprovedQuotations")
  reviewedEstimates  EstimateRequest[]  @relation("ReviewedEstimates")
  estimateRevisions  EstimateRevision[]
  auditLogs          AuditLog[]

  @@index([fullName])
  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Customer {
  id               String            @id @default(uuid())
  fullName         String
  companyName      String?
  email            String
  mobileNumber     String
  address          String
  city             String
  province         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  inquiries        Inquiry[]
  estimateRequests EstimateRequest[]
  quotations       Quotation[]

  @@index([fullName])
  @@index([companyName])
  @@index([email])
  @@index([mobileNumber])
  @@index([city])
  @@index([province])
}

model Inquiry {
  id              String        @id @default(uuid())
  referenceNumber String        @unique
  customerId      String?
  fullName        String
  email           String
  mobileNumber    String
  subject         String
  message         String
  status          InquiryStatus @default(NEW)
  source          InquirySource @default(CONTACT_FORM)
  internalNotes   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([fullName])
  @@index([email])
  @@index([mobileNumber])
  @@index([subject])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model EstimateRequest {
  id                         String                @id @default(uuid())
  estimateNumber             String                @unique
  customerId                 String
  propertyType               String
  serviceAddress             String
  airconType                 String
  airconCapacity             String
  quantity                   Int
  brand                      String?
  unitCondition              String                @default("EXISTING")
  indoorUnitLocation         String?
  outdoorUnitLocation        String?
  selectedService            String
  preferredDate              DateTime?
  notes                      String
  urgencyLevel               String                @default("STANDARD")
  estimatedSubtotal          Decimal               @default(0)
  estimatedAdditionalFees    Decimal               @default(0)
  estimatedTax               Decimal               @default(0)
  estimatedTotal             Decimal               @default(0)
  publicAccessTokenHash      String?               @unique
  publicAccessTokenEncrypted String?
  publicAccessTokenIv        String?
  publicAccessTokenAuthTag   String?
  publicAccessTokenExpiresAt DateTime?
  publicAccessTokenCreatedAt DateTime?
  publicAccessLastAccessedAt DateTime?
  publicAccessDisabledAt     DateTime?
  reviewedById               String?
  reviewedAt                 DateTime?
  reviewSummary              String?
  recommendedSiteInspection  Boolean               @default(false)
  recommendedServiceDate     DateTime?
  internalNotes              String?
  status                     EstimateRequestStatus @default(SUBMITTED)
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  customer                   Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  reviewedBy                 AdminUser?            @relation("ReviewedEstimates", fields: [reviewedById], references: [id], onDelete: SetNull)
  quotation                  Quotation?
  revisions                  EstimateRevision[]

  @@index([customerId])
  @@index([reviewedById])
  @@index([propertyType])
  @@index([airconType])
  @@index([selectedService])
  @@index([preferredDate])
  @@index([status])
  @@index([publicAccessTokenExpiresAt])
  @@index([publicAccessDisabledAt])
  @@index([createdAt])
}

model EstimateRevision {
  id                 String          @id @default(uuid())
  estimateRequestId  String
  revisionNumber     Int
  serviceDescription String
  quantity           Int
  baseAmount         Decimal         @default(0)
  capacityAdjustment Decimal         @default(0)
  urgencyAdjustment  Decimal         @default(0)
  additionalFees     Decimal         @default(0)
  discount           Decimal         @default(0)
  taxRate            Decimal         @default(0)
  taxAmount          Decimal         @default(0)
  subtotal           Decimal         @default(0)
  total              Decimal         @default(0)
  notes              String?
  createdById        String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  estimateRequest    EstimateRequest @relation(fields: [estimateRequestId], references: [id], onDelete: Cascade)
  createdBy          AdminUser       @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([estimateRequestId, revisionNumber])
  @@index([estimateRequestId])
  @@index([createdById])
  @@index([createdAt])
}

model Quotation {
  id                   String           @id @default(uuid())
  quotationNumber      String           @unique
  customerId           String
  estimateRequestId    String?          @unique
  projectTitle         String           @default("Untitled Project")
  customerFullName     String?
  customerCompanyName  String?
  customerEmail        String?
  customerMobileNumber String?
  billingAddress       String?
  serviceAddress       String?
  quotationDate        DateTime
  validUntil           DateTime
  subtotal             Decimal          @default(0)
  discount             Decimal          @default(0)
  taxRate              Decimal          @default(0)
  taxAmount            Decimal          @default(0)
  additionalFees       Decimal          @default(0)
  grandTotal           Decimal          @default(0)
  scopeOfWork          String
  exclusions           String
  paymentTerms         String
  warrantyTerms        String
  notes                String
  preparedById         String
  approvedById         String?
  status               QuotationStatus  @default(DRAFT)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  customer             Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  estimateRequest      EstimateRequest? @relation(fields: [estimateRequestId], references: [id], onDelete: SetNull)
  preparedBy           AdminUser        @relation("PreparedQuotations", fields: [preparedById], references: [id], onDelete: Restrict)
  approvedBy           AdminUser?       @relation("ApprovedQuotations", fields: [approvedById], references: [id], onDelete: SetNull)
  items                QuotationItem[]

  @@index([customerId])
  @@index([preparedById])
  @@index([approvedById])
  @@index([quotationDate])
  @@index([validUntil])
  @@index([status])
  @@index([createdAt])
}

model QuotationItem {
  id          String            @id @default(uuid())
  quotationId String
  itemType    QuotationItemType
  description String
  quantity    Decimal
  unit        String
  unitPrice   Decimal           @default(0)
  amount      Decimal           @default(0)
  discount    Decimal           @default(0)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  quotation   Quotation         @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([itemType])
  @@index([description])
  @@index([sortOrder])
}

model AuditLog {
  id              String     @id @default(uuid())
  adminId         String?
  action          String
  entityType      String
  entityId        String?
  entityReference String?
  metadata        String?
  createdAt       DateTime   @default(now())
  admin           AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model CompanySetting {
  id                           String              @id @default(uuid())
  companyName                  String
  companyAddress               String
  companyPhone                 String
  companyEmail                 String
  companyWebsite               String?
  companyLogoPath              String?
  currencyCode                 String              @default("PHP")
  facebookUrl                  String?
  linkedinUrl                  String?
  founderName                  String?
  founderRole                  String?
  founderExperienceYears       String?
  founderShortBiography        String?
  founderFullBiography         String?
  founderCurrentResponsibility String?
  founderImagePath             String?
  founderExpertise             String?
  homeHeroEyebrow              String?
  homeHeroTitle                String?
  homeHeroSubtitle             String?
  homePrimaryCtaLabel          String?
  homePrimaryCtaPath           String?
  homeSecondaryCtaLabel        String?
  homeSecondaryCtaPath         String?
  homeStats                    String?
  homeWhyEyebrow               String?
  homeWhyTitle                 String?
  homeWhyDescription           String?
  homeServicesEyebrow          String?
  homeServicesTitle            String?
  homeServicesDescription      String?
  homeAboutEyebrow             String?
  homeAboutTitle               String?
  homeAboutDescription         String?
  homeAboutCtaLabel            String?
  homeProjectsEyebrow          String?
  homeProjectsTitle            String?
  homeProjectsDescription      String?
  homeTestimonialsEyebrow      String?
  homeTestimonialsTitle        String?
  homeTestimonialsDescription  String?
  aboutHeroEyebrow             String?
  aboutHeroTitle               String?
  aboutHeroDescription         String?
  aboutIntroTitle              String?
  aboutIntroParagraphs         String?
  aboutCommitmentTitle         String?
  aboutCommitmentDescription   String?
  aboutMissionTitle            String?
  aboutMissionDescription      String?
  aboutVisionTitle             String?
  aboutVisionDescription       String?
  aboutValuesEyebrow           String?
  aboutValuesTitle             String?
  aboutValuesDescription       String?
  aboutCoreValues              String?
  aboutWhyEyebrow              String?
  aboutWhyTitle                String?
  aboutWhyDescription          String?
  aboutWhyItems                String?
  aboutFinalTitle              String?
  aboutFinalDescription        String?
  quotationValidityDays        Int                 @default(30)
  estimateValidityDays         Int                 @default(7)
  taxRate                      Decimal             @default(0)
  estimateDisclaimer           String
  quotationTerms               String
  quotationFooter              String?
  registrationDetails          String?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  homeCarouselImages           HomeCarouselImage[]
  publicServices               PublicService[]

  @@index([companyName])
  @@index([companyEmail])
}

model HomeCarouselImage {
  id               String         @id @default(uuid())
  companySettingId String
  imagePath        String
  altText          String
  caption          String?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  companySetting   CompanySetting @relation(fields: [companySettingId], references: [id], onDelete: Cascade)

  @@index([companySettingId])
  @@index([sortOrder])
}

model PublicService {
  id               String         @id @default(uuid())
  companySettingId String
  serviceKey       String         @unique
  name             String
  summary          String
  description      String
  imagePath        String?
  sortOrder        Int            @default(0)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  companySetting   CompanySetting @relation(fields: [companySettingId], references: [id], onDelete: Cascade)

  @@index([companySettingId])
  @@index([serviceKey])
  @@index([sortOrder])
  @@index([isActive])
}
